APP_ENV=development
HTTP_ADDR=:8080
APP_BASE_URL=http://localhost:8080
DATABASE_URL=postgres://firewall:firewall@localhost:5432/firewall?sslmode=disable
JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=firewall-manager
JWT_TTL_MINUTES=480
BOOTSTRAP_TOKEN=replace-with-bootstrap-token
FIREWALL_PROVIDER=nftables
FIREWALL_DRY_RUN=true
NFTABLES_BIN=nft
OPNSENSE_BASE_URL=https://opnsense.local
OPNSENSE_API_KEY=replace-with-opnsense-key
OPNSENSE_API_SECRET=replace-with-opnsense-secret
